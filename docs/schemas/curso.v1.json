{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://essd.vicente.trabalho/schemas/curso.v1.json",
  "title": "Curso",
  "description": "Esquema canônico de Curso do Sistema de Matrícula.",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Identificador interno do curso (Primary Key)",
      "minimum": 1
    },
    "codigo": {
      "type": "string",
      "description": "Código da instituição para o curso (Ex: CC01)",
      "maxLength": 10
    },
    "nome": {
      "type": "string",
      "description": "Nome completo do curso (Ex: Ciência da Computação)",
      "maxLength": 100
    },
    "turno": {
      "type": "string",
      "description": "Turno do curso (Ex: Diurno, Noturno, Integral)",
      "maxLength": 50
    },
    "grau": {
      "type": "string",
      "description": "Grau acadêmico (Ex: Bacharelado, Licenciatura)",
      "maxLength": 50
    },
    "modalidade": {
      "type": "string",
      "description": "Modalidade de ensino (Ex: Presencial, EAD)",
      "maxLength": 50
    },
    "sede": {
      "type": "string",
      "description": "Campus ou sede (Ex: Campus Darcy Ribeiro)",
      "maxLength": 100
    },
    "coordenador_id": {
      "anyOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ],
      "description": "ID do docente coordenador do curso"
    },
    "unidade_organizacional_id": {
      "anyOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ],
      "description": "ID da unidade organizacional (departamento/instituto)"
    },
    "ativo": {
      "type": "boolean",
      "description": "Indica se o curso ainda aceita ingresso de alunos e funciona",
      "default": true
    }
  },
  "required": ["codigo", "nome"]
}
